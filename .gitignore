# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# dependencies
/frontend/node_modules
/frontend/.pnp
/frontend/.pnp.*
/frontend/.yarn/*
!/frontend/.yarn/patches
!/frontend/.yarn/plugins
!/frontend/.yarn/releases
!/frontend/.yarn/versions

# testing
/frontend/coverage

# next.js build artefacts
/frontend/.next/
/frontend/out/
/frontend/build

# env files — opt-in to commit if needed
/frontend/.env*
!/frontend/.env.example
!/frontend/.env.local.example

# typescript generated files
next-env.d.ts
*.tsbuildinfo

# next.js build artefacts at any depth (catches stale root-level .next)
.next/

# ── Backend (Express) ─────────────────────────────────────────────────────────

/backend/node_modules
/backend/dist
/backend/.env
!/backend/.env.example
/backend/*.tsbuildinfo

# ── IDE / Tooling ─────────────────────────────────────────────────────────────

.claude/

# ── Misc ─────────────────────────────────────────────────────────────────────

# Catch-all for any stray node_modules at the root
/node_modules

.DS_Store
*.pem
Thumbs.db

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# Claude assistant files
AGENTS.md
CLAUDE.md