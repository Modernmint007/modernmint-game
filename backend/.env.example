# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/modernmint

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes).
# On Render, set this to your deployed frontend URL:
#   FRONTEND_URL=https://your-app.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000
